{
  "id": "start-button-hidden-when-not-planned",
  "testPlanId": "3ff55ff4-2443-4d28-8efb-ec4f9577c4cf",
  "requirementId": "4f657384-5930-4064-a8a3-501b0c22e0a0",
  "suiteName": "Certinia PSA - Start Planned Project Task",
  "case": {
    "id": "start-button-hidden-when-not-planned",
    "title": "Verify Start button is not available for non-Planned Project Task",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Project 'Perry's Restaurants, - Q-453446 - Ready Fixed Fee Implementation' exists.",
      "Project has at least one Project Task with Status != Planned (e.g., Started or Completed)."
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Open Salesforce Home page",
        "value": "https://ukgsf--stest.sandbox.lightning.force.com/lightning/page/home"
      },
      {
        "id": "s2",
        "action": "waitForVisible",
        "targetDescription": "Global Search input visible",
        "locatorHint": "input[title='Search']"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Type full project name in Search",
        "locatorHint": "input[title='Search']",
        "value": "Perry's Restaurants, - Q-453446 - Ready Fixed Fee Implementation"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Search result for the exact Project appears",
        "locatorHint": "div[role='listbox'] a:has-text(\"Perry's Restaurants, - Q-453446 - Ready Fixed Fee Implementation\")"
      },
      {
        "id": "s5",
        "action": "tap",
        "targetDescription": "Select the Project from search results",
        "locatorHint": "div[role='listbox'] a:has-text(\"Perry's Restaurants, - Q-453446 - Ready Fixed Fee Implementation\")"
      },
      {
        "id": "s6",
        "action": "waitForVisible",
        "targetDescription": "Project record header is visible",
        "locatorHint": "records-lwc-detail-panel h1[title='Project']"
      },
      {
        "id": "s7",
        "action": "scrollIntoView",
        "targetDescription": "Scroll to Related Lists section",
        "locatorHint": "div.slds-card__header-title:has-text('Related Lists')"
      },
      {
        "id": "s8",
        "action": "tap",
        "targetDescription": "Click Show All in Related Lists",
        "locatorHint": "a[title='Show All']"
      },
      {
        "id": "s9",
        "action": "waitForVisible",
        "targetDescription": "Related Lists page loaded",
        "locatorHint": "h1:has-text('Related Lists')"
      },
      {
        "id": "s10",
        "action": "tap",
        "targetDescription": "Open Project Tasks related list",
        "locatorHint": "a[title='Project Tasks']"
      },
      {
        "id": "s11",
        "action": "waitForVisible",
        "targetDescription": "Project Tasks list rendered",
        "locatorHint": "table[role='grid']"
      },
      {
        "id": "s12",
        "action": "tap",
        "targetDescription": "Open a task where Status = Started (non-Planned)",
        "locatorHint": "table[role='grid'] tbody tr:has(td[data-label='Status'] >> text=Started) a[role='link']"
      },
      {
        "id": "s13",
        "action": "waitForVisible",
        "targetDescription": "Project Task details page header visible",
        "locatorHint": "records-lwc-detail-panel h1[title='Project Task']"
      },
      {
        "id": "s14",
        "action": "assertContainsText",
        "targetDescription": "Verify Status field shows Started",
        "locatorHint": "[data-field='Status']",
        "assertion": "Started"
      },
      {
        "id": "s15",
        "action": "assertHidden",
        "targetDescription": "Verify Start button is not visible when Status != Planned",
        "locatorHint": "button:has-text('Start')"
      },
      {
        "id": "s16",
        "action": "assertContainsText",
        "targetDescription": "Verify Started field indicates Checked/selected",
        "locatorHint": "[data-field='Started']",
        "assertion": "Checked"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
