          },
          {
            "id": "s12",
            "action": "tap",
            "targetDescription": "Open a task where Status = Planned",
            "locatorHint": "table[role='grid'] tbody tr:has(td[data-label='Status'] >> text=Planned) a[role='link']"
          },
          {
            "id": "s13",
            "action": "waitForVisible",
            "targetDescription": "Project Task details page header visible",
            "locatorHint": "records-lwc-detail-panel h1[title='Project Task']"
          },
          {
            "id": "s14",
            "action": "assertContainsText",
            "targetDescription": "Verify Status field shows Planned",
            "locatorHint": "[data-field='Status']",
            "assertion": "Planned"
          },
          {
            "id": "s15",
            "action": "assertVisible",
            "targetDescription": "Verify Started field is present",
            "locatorHint": "[data-field='Started']"
          },
          {
            "id": "s16",
            "action": "assertVisible",
            "targetDescription": "Verify Actual Start Date field is present",
            "locatorHint": "[data-field='Actual Start Date']"
          },
          {
            "id": "s17",
            "action": "assertVisible",
            "targetDescription": "Verify Start button is visible",
            "locatorHint": "button:has-text('Start')"
          },
          {
            "id": "s18",
            "action": "assertEnabled",
            "targetDescription": "Verify Start button is enabled",
            "locatorHint": "button:has-text('Start')"
          },
          {
            "id": "s19",
            "action": "tap",
            "targetDescription": "Click Start to begin the task",
            "locatorHint": "button:has-text('Start')"
          },
          {
            "id": "s20",
            "action": "waitForVisible",
            "targetDescription": "Wait for Status to update to Started",
            "locatorHint": "[data-field='Status']"
          },
          {
            "id": "s21",
            "action": "assertContainsText",
            "targetDescription": "Confirm Status changed to Started",
            "locatorHint": "[data-field='Status']",
            "assertion": "Started"
          },
          {
            "id": "s22",
            "action": "assertContainsText",
            "targetDescription": "Confirm Started field indicates Checked/selected",
            "locatorHint": "[data-field='Started']",
            "assertion": "Checked"
          },
          {
            "id": "s23",
            "action": "assertContainsText",
            "targetDescription": "Confirm Actual Start Date is set to current date",
            "locatorHint": "[data-field='Actual Start Date']",
            "assertion": "{{today}}"
          },
          {
            "id": "s24",
            "action": "assertHidden",
            "targetDescription": "Verify Start button no longer visible after starting",
            "locatorHint": "button:has-text('Start')"
          }
        ],
        "tags": [
          "@e2e",
          "@regression"
        ]
      },
