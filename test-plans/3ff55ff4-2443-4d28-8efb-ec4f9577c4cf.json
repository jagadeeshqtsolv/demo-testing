        "priority": "P0",
        "platforms": [
          "chrome"
        ],
        "preconditions": [],
        "steps": [
          {
            "id": "s1",
            "action": "openUrl",
            "targetDescription": "Open Salesforce Home page",
            "value": "https://ukgsf--stest.sandbox.lightning.force.com/lightning/page/home"
          },
          {
            "id": "s2",
            "action": "waitForVisible",
            "targetDescription": "Search input visible",
            "locatorHint": "input[title='Search']",
            "screenName": "Home",
            "pageObjectMethod": "expectSearchVisible"
          },
          {
            "id": "s3",
            "action": "fill",
            "targetDescription": "Type full project name in Search",
            "locatorHint": "input[title='Search']",
